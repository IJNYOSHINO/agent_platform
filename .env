# ── LLM 配置 ────────────────────────────────────────────────
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
API_KEY=sk-2c00fb9db2b94fdd8ba63df59a73f721

# 可选覆盖（默认值见 config/settings.py）
MODEL=qwen-vl-plus
# MODEL_PROVIDER=openai

# ── 运行环境 ────────────────────────────────────────────────
# ENV=dev       # dev: MemorySaver (内存)
# ENV=prod      # prod: SqliteSaver (持久化)

# ── 数据路径 ────────────────────────────────────────────────
# SQLITE_PATH=data/agent.db
# FAISS_INDEX_PATH=data/faiss.index
# MEMORY_META_PATH=data/memory_meta.json

# ── 执行引擎 ────────────────────────────────────────────────
# STEP_TIMEOUT=30
# STEP_MAX_RETRIES=3
# RETRY_BASE_DELAY=1.0

# ── 记忆系统 ────────────────────────────────────────────────
# MEMORY_TOP_K=5
# MEMORY_TOKEN_LIMIT=2000
EMBEDDING_MODEL=tongyi-embedding-vision-plus
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding

# Database and auth
DATABASE_URL=postgresql+psycopg://postgres:123123@localhost:5432/agent_platform
CHECKPOINT_DATABASE_URL=postgresql://postgres:123123@localhost:5432/agent_platform
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
